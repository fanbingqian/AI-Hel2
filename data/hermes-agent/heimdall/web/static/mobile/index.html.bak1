<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
<title>HEIMDALL · 知识环</title>
<style>
/* ===================================================================
   HEIMDALL Mobile UI — V2.2 响应式单页
   Design: 4 anchors — chat-first, auto-record, card-flow, shortest-correction
   =================================================================== */

:root {
  --bg-deep: #0f0f13; --bg-raised: #16161e; --bg-card: #1c1c28;
  --surface: #222230; --border: #2e2e3c; --border-light: #3d3d50;
  --text: #ebebf5; --text-muted: #9d9db5; --text-weak: #6e6e85;
  --accent: #6c5ce7; --accent-purple: #9b8cf0; --blue: #5d9bff;
  --green: #2dd4a0; --amber: #f6b83d; --red: #f06565;
  --pink: #f06ba8; --cyan: #2dd4c8;
  --safe-bottom: env(safe-area-inset-bottom, 0px);
  --space-xs: 4px; --space-sm: 8px; --space-md: 12px; --space-lg: 16px;
  --radius-sm: 6px; --radius-md: 10px; --radius-lg: 16px; --radius-xl: 20px; --radius-full: 9999px;
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --ease-in-out: cubic-bezier(0.65, 0, 0.35, 1);
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
}
* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', sans-serif;
  background: var(--bg-deep); color: var(--text); height: 100dvh; overflow: hidden;
  display: flex; flex-direction: column; user-select: none; -webkit-user-select: none;
}

/* ====== Top Bar ====== */
.topbar {
  display: flex; align-items: center; justify-content: space-between; padding: 10px 16px;
  background: var(--bg-raised); border-bottom: 1px solid var(--border); height: 48px;
  flex-shrink: 0; z-index: 10;
}
.topbar .brand { display: flex; align-items: center; gap: 8px; font-size: 16px; font-weight: 700; }
.topbar .brand span { background: linear-gradient(135deg, var(--accent), var(--accent-purple)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
.topbar .actions { display: flex; gap: 12px; position: relative; }
.topbar .actions button { background: none; border: none; color: var(--text-muted); font-size: 18px; cursor: pointer; padding: 4px; position: relative; }
.topbar .actions button:active { color: var(--accent); }
.topbar .badge { position: absolute; top: 2px; right: 2px; width: 8px; height: 8px; border-radius: 50%; background: var(--red); display: none; }
.topbar .badge.show { display: block; }

/* ====== Content Area ====== */
.content { flex: 1; overflow-y: auto; overflow-x: hidden; -webkit-overflow-scrolling: touch; }
.page { display: none; min-height: 100%; padding-bottom: 80px; }
.page.active { display: block; }
.page.chat-page { display: none; flex-direction: column; }
.page.chat-page.active { display: flex; }

/* ====== Bottom Nav ====== */
.bottom-nav {
  display: flex; justify-content: space-around; align-items: center;
  height: calc(60px + var(--safe-bottom)); padding-bottom: var(--safe-bottom);
  background: var(--bg-raised); border-top: 1px solid var(--border);
  flex-shrink: 0; z-index: 10;
  backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
}
.bottom-nav button {
  flex: 1; display: flex; flex-direction: column; align-items: center; gap: 2px;
  padding: 8px 0; border: none; background: none; color: var(--text-weak);
  font-size: 10px; cursor: pointer; transition: all 0.15s; position: relative;
}
.bottom-nav button .nav-icon { font-size: 20px; transition: transform 0.2s; }
.bottom-nav button.active .nav-icon { transform: scale(1.1); }
.bottom-nav button.active { color: var(--accent); }
.bottom-nav button.active::before {
  content: ''; position: absolute; top: 0; left: 25%; right: 25%; height: 2px;
  background: linear-gradient(90deg, var(--accent), var(--accent-purple)); border-radius: 1px;
}

/* ===================================================================
   CHAT PAGE
   =================================================================== */

/* Empty state */
.chat-empty {
  flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 40px 24px; text-align: center;
}
.chat-empty .icon {
  font-size: 56px; margin-bottom: 16px;
  animation: float 3s ease-in-out infinite;
}
@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
.chat-empty h2 { font-size: 18px; font-weight: 600; margin-bottom: 6px; }
.chat-empty p { font-size: 13px; color: var(--text-muted); margin-bottom: 24px; max-width: 260px; }
.suggestions { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; }
.suggestion {
  padding: 8px 14px; border-radius: 16px; border: 1px solid var(--border-light);
  background: var(--bg-card); color: var(--text-muted); font-size: 13px;
  cursor: pointer; transition: all 0.15s; max-width: 200px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.suggestion:active { border-color: var(--accent); color: var(--accent); background: #7c6aff15; }

/* Messages */
.chat-msgs { flex: 1; overflow-y: auto; padding: 12px 16px; display: flex; flex-direction: column; gap: 12px; }
.date-divider { text-align: center; font-size: 11px; color: var(--text-weak); padding: 8px 0; }
.msg-row { display: flex; gap: 8px; max-width: 85%; animation: msgIn 200ms ease-out; }
@keyframes msgIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
.msg-row.user { align-self: flex-end; flex-direction: row-reverse; }
.msg-row.assistant { align-self: flex-start; }
.msg-avatar {
  width: 30px; height: 30px; border-radius: 50%; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center; font-size: 14px;
}
.msg-row.user .msg-avatar { background: linear-gradient(135deg, var(--accent), var(--accent-purple)); }
.msg-row.assistant .msg-avatar { background: var(--bg-card); border: 1px solid var(--border); }
.msg-bubble {
  padding: 10px 14px; border-radius: 16px; font-size: 14px; line-height: 1.6; word-break: break-word;
}
.msg-row.user .msg-bubble { background: linear-gradient(135deg, var(--accent), #8b5cf6); color: #fff; border-bottom-right-radius: 6px; }
.msg-row.assistant .msg-bubble { background: var(--bg-card); border: 1px solid var(--border); border-bottom-left-radius: 6px; }
.msg-row.assistant .reasoning-toggle {
  font-size: 11px; color: var(--amber); margin-top: 4px; cursor: pointer; display: flex; align-items: center; gap: 4px;
}
.reasoning-content { font-size: 12px; color: var(--text-muted); margin-top: 4px; padding: 8px; background: var(--bg-deep); border-radius: 8px; display: none; }
.reasoning-content.open { display: block; }

/* Typing indicator */
.typing-indicator { display: none; align-self: flex-start; padding: 10px 16px; }
.typing-indicator.show { display: flex; gap: 4px; }
.typing-indicator span {
  width: 6px; height: 6px; border-radius: 50%; background: var(--text-muted);
  animation: bounce 1.4s ease-in-out infinite;
}
.typing-indicator span:nth-child(1) { animation-delay: 0s; }
.typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
.typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce { 0%,80%,100%{transform:scale(0.6);opacity:0.4} 40%{transform:scale(1);opacity:1} }

/* Input bar */
.chat-input-wrap {
  padding: 8px 12px; background: var(--bg-raised); border-top: 1px solid var(--border);
  flex-shrink: 0; display: flex; gap: 8px; align-items: flex-end;
}
.chat-input-wrap textarea {
  flex: 1; padding: 10px 14px; border-radius: 20px; border: 1px solid var(--border);
  background: var(--bg-card); color: var(--text); font-size: 15px; resize: none;
  outline: none; min-height: 40px; max-height: 120px; font-family: inherit; line-height: 1.4;
  transition: border-color 0.2s;
}
.chat-input-wrap textarea:focus { border-color: var(--accent); }
.chat-input-wrap .btn-mic, .chat-input-wrap .btn-send {
  width: 40px; height: 40px; border-radius: 50%; border: none; cursor: pointer;
  display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0;
  transition: all 0.15s;
}
.chat-input-wrap .btn-mic { background: var(--bg-card); color: var(--text-muted); }
.chat-input-wrap .btn-mic.recording { background: var(--red); color: #fff; animation: pulse-ring 1.2s infinite; }
@keyframes pulse-ring {
  0% { box-shadow: 0 0 0 0 rgba(248,113,113,0.4); }
  70% { box-shadow: 0 0 0 10px rgba(248,113,113,0); }
  100% { box-shadow: 0 0 0 0 rgba(248,113,113,0); }
}
.chat-input-wrap .btn-send { background: linear-gradient(135deg, var(--accent), var(--accent-purple)); color: #fff; }
.chat-input-wrap .btn-send:active { transform: scale(0.95); }
.chat-input-wrap .btn-stop { background: var(--red) !important; }

/* ===================================================================
   RING PAGE
   =================================================================== */

/* Stats bar */
.stats-bar { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; padding: 16px; }
.stat-card {
  background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px;
  padding: 14px 8px; text-align: center;
}
.stat-card .stat-num { font-size: 22px; font-weight: 700; background: linear-gradient(135deg, var(--text), var(--accent-purple)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
.stat-card .stat-label { font-size: 11px; color: var(--text-muted); margin-top: 2px; }

/* Ring Graph */
.ring-graph-wrap {
  position: relative; width: 100%; height: 50vh; min-height: 280px;
  background: var(--bg-deep); border: 1px solid var(--border); border-radius: 16px;
  overflow: hidden; margin: 0 16px 8px;
}
.ring-graph-wrap svg { width: 100%; height: 100%; display: block; }
.ring-graph-legend {
  display: flex; flex-wrap: wrap; gap: 8px; padding: 4px 16px 8px;
  font-size: 10px; color: var(--text-muted); justify-content: center;
}
.ring-graph-legend span { display: inline-flex; align-items: center; gap: 4px; }
.ring-graph-legend .lg-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }

/* Search */
.search-wrap { padding: 0 16px 12px; }
.search-wrap input {
  width: 100%; padding: 10px 14px 10px 34px; border-radius: 12px;
  border: 1px solid var(--border); background: var(--bg-card); color: var(--text);
  font-size: 14px; outline: none;
}
.search-wrap input:focus { border-color: var(--accent); }
.search-wrap { position: relative; }
.search-wrap::before { content: '🔍'; position: absolute; left: 26px; top: 10px; font-size: 14px; pointer-events: none; }

/* Domain cards */
.domain-list { padding: 0 16px; display: flex; flex-direction: column; gap: 10px; }
.domain-card {
  background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px;
  padding: 14px; cursor: pointer; transition: all 0.15s; position: relative; overflow: hidden;
}
.domain-card:active { border-color: var(--accent); transform: scale(0.985); }
.domain-card .dc-left { position: absolute; left: 0; top: 0; bottom: 0; width: 3px; }
.domain-card .dc-header { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
.domain-card .dc-name { font-size: 14px; font-weight: 600; }
.domain-card .dc-count { font-size: 11px; color: var(--text-muted); }
.domain-card .dc-new { font-size: 10px; padding: 2px 6px; border-radius: 8px; background: var(--green); color: #000; font-weight: 600; }
.domain-card .dc-tags { display: flex; flex-wrap: wrap; gap: 6px; }
.domain-card .dc-tag {
  padding: 4px 10px; border-radius: 12px; font-size: 12px;
  background: var(--surface); color: var(--text-muted); border: 1px solid var(--border);
}
.social-update { font-size: 13px; color: var(--cyan); }
.progress-bar { height: 4px; border-radius: 2px; background: var(--border); margin-top: 4px; overflow: hidden; }
.progress-bar .fill { height: 100%; border-radius: 2px; background: linear-gradient(90deg, var(--accent), var(--accent-purple)); transition: width 0.6s; }

/* Empty state ring */
.ring-empty {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 60px 24px; text-align: center;
}
.ring-svg { width: 120px; height: 120px; margin-bottom: 20px; }
.ring-svg .dot { animation: pulse-dot 1.8s ease-in-out infinite; }
@keyframes pulse-dot { 0%,100%{r:4;opacity:0.6} 50%{r:8;opacity:1} }
.ring-empty h3 { font-size: 16px; font-weight: 600; margin-bottom: 4px; }
.ring-empty p { font-size: 13px; color: var(--text-muted); }

/* Search results */
.search-results { padding: 0 16px; display: none; flex-direction: column; gap: 6px; }
.search-results.open { display: flex; }
.search-result-item {
  display: flex; align-items: center; gap: 10px; padding: 12px;
  background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px;
  cursor: pointer; transition: all 0.15s;
}
.search-result-item:active { border-color: var(--accent); }
.search-result-item .sri-icon { font-size: 20px; }
.search-result-item .sri-info { flex: 1; }
.search-result-item .sri-name { font-size: 14px; font-weight: 500; }
.search-result-item .sri-sub { font-size: 11px; color: var(--text-muted); }
.search-result-item .sri-type {
  padding: 3px 8px; border-radius: 10px; font-size: 10px; font-weight: 600;
}
.type-concept { background: #3b82f620; color: var(--blue); }
.type-content { background: #10b98120; color: var(--green); }
.type-person { background: #f59e0b20; color: var(--amber); }
.type-event { background: #ef444420; color: var(--red); }
.type-artifact { background: #8b5cf620; color: var(--accent-purple); }

/* ===================================================================
   PROFILE PAGE
   =================================================================== */

.profile-header {
  display: flex; flex-direction: column; align-items: center; padding: 32px 24px 20px; text-align: center;
}
.profile-avatar {
  width: 64px; height: 64px; border-radius: 50%;
  background: linear-gradient(135deg, var(--accent), var(--accent-purple));
  display: flex; align-items: center; justify-content: center; font-size: 28px;
  margin-bottom: 12px; box-shadow: 0 4px 20px rgba(124,106,255,0.3);
}
.profile-header h2 { font-size: 16px; font-weight: 600; margin-bottom: 2px; }
.profile-header p { font-size: 13px; color: var(--text-muted); }

.settings-group { padding: 0 16px 16px; }
.settings-group .sg-title {
  font-size: 11px; color: var(--text-weak); text-transform: uppercase;
  letter-spacing: 0.5px; padding: 0 4px 8px;
}
.settings-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 12px; background: var(--bg-card); border: 1px solid var(--border);
  cursor: pointer; transition: all 0.15s;
}
.settings-item:first-of-type { border-radius: 14px 14px 0 0; }
.settings-item:last-of-type { border-radius: 0 0 14px 14px; }
.settings-item:only-of-type { border-radius: 14px; }
.settings-item + .settings-item { border-top: none; }
.settings-item:active { background: var(--surface); }
.settings-item .si-left { display: flex; align-items: center; gap: 10px; }
.settings-item .si-icon { font-size: 18px; }
.settings-item .si-info { display: flex; flex-direction: column; }
.settings-item .si-label { font-size: 14px; }
.settings-item .si-desc { font-size: 11px; color: var(--text-muted); }
.settings-item .si-arrow { color: var(--text-weak); font-size: 14px; }

/* Toggle switch */
.toggle {
  width: 44px; height: 26px; border-radius: 13px; background: var(--border);
  position: relative; cursor: pointer; transition: background 0.25s;
}
.toggle.on { background: var(--accent); }
.toggle::after {
  content: ''; position: absolute; top: 3px; left: 3px;
  width: 20px; height: 20px; border-radius: 50%; background: #fff;
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.toggle.on::after { transform: translateX(18px); }

/* ===================================================================
   OVERLAYS: Bottom Sheet, Modal, Toast
   =================================================================== */

.overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 50; }
.overlay.open { display: block; }

/* Bottom sheet */
.bottom-sheet {
  position: fixed; bottom: 0; left: 0; right: 0; max-height: 80vh;
  background: var(--bg-raised); border-radius: 20px 20px 0 0;
  z-index: 60; transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  display: flex; flex-direction: column; overflow: hidden;
}
.bottom-sheet.open { transform: translateY(0); }
.bottom-sheet .bs-handle {
  width: 32px; height: 4px; border-radius: 2px; background: var(--border-light);
  margin: 10px auto; flex-shrink: 0;
}
.bottom-sheet .bs-content { padding: 0 20px 24px; overflow-y: auto; flex: 1; }
.bottom-sheet .bs-entity-name { font-size: 20px; font-weight: 700; margin-bottom: 4px; }
.bottom-sheet .bs-entity-type {
  display: inline-block; padding: 3px 10px; border-radius: 10px; font-size: 11px;
  font-weight: 600; margin-bottom: 12px;
}
.bottom-sheet .bs-section { margin-top: 14px; }
.bottom-sheet .bs-section h4 { font-size: 11px; color: var(--text-muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
.bottom-sheet .bs-domain-tags { display: flex; flex-wrap: wrap; gap: 6px; }
.bottom-sheet .bs-domain-tag {
  padding: 4px 10px; border-radius: 12px; font-size: 12px;
  background: var(--surface); color: var(--accent-purple); border: 1px solid var(--border); cursor: pointer;
}
.bottom-sheet .bs-relations { display: flex; flex-direction: column; gap: 8px; }
.bottom-sheet .bs-rel-item {
  display: flex; align-items: center; gap: 8px; font-size: 13px; padding: 8px;
  background: var(--bg-card); border-radius: 10px;
}
.bottom-sheet .bs-rel-type { font-size: 10px; color: var(--text-muted); }
.bottom-sheet .btn-correct {
  width: 100%; padding: 12px; border-radius: 12px; border: 1px solid var(--amber);
  background: #fbbf2410; color: var(--amber); font-size: 14px; font-weight: 600;
  cursor: pointer; margin-top: 14px;
}

/* Modal */
.modal {
  position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 70;
  display: none; align-items: center; justify-content: center; padding: 24px;
}
.modal.open { display: flex; }
.modal-box {
  background: var(--bg-raised); border: 1px solid var(--border); border-radius: 16px;
  padding: 20px; width: 100%; max-width: 360px; max-height: 70vh; overflow-y: auto;
}
.modal-box h3 { font-size: 16px; font-weight: 600; margin-bottom: 4px; display: flex; align-items: center; gap: 8px; }
.modal-box .modal-close { float: right; background: none; border: none; color: var(--text-muted); font-size: 18px; cursor: pointer; }
.modal-box .modal-section { margin-top: 12px; }
.modal-box .modal-section h4 { font-size: 12px; color: var(--text-muted); margin-bottom: 4px; }
.modal-box .modal-item { font-size: 13px; padding: 6px 0; display: flex; align-items: center; gap: 6px; }
.modal-box .modal-arrow { color: var(--text-weak); font-size: 11px; }

/* Toast */
.toast {
  position: fixed; top: 56px; left: 50%; transform: translateX(-50%); z-index: 80;
  padding: 10px 20px; border-radius: 10px; background: var(--bg-card); border: 1px solid var(--border);
  color: var(--text); font-size: 13px; pointer-events: none;
  opacity: 0; transition: opacity 0.25s ease-out;
  box-shadow: 0 4px 16px rgba(0,0,0,0.4);
}
.toast.show { opacity: 1; }
.toast.success { border-color: var(--green); }
.toast.error { border-color: var(--red); }

/* ===================================================================
   CORRECTION PROMPT
   =================================================================== */

.correct-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 70; align-items: flex-end; }
.correct-overlay.open { display: flex; }
.correct-prompt {
  width: 100%; background: var(--bg-raised); border-radius: 20px 20px 0 0;
  padding: 20px; display: flex; flex-direction: column; gap: 10px;
}
.correct-prompt h4 { font-size: 15px; }
.correct-prompt textarea {
  width: 100%; padding: 12px; border-radius: 12px; border: 1px solid var(--border);
  background: var(--bg-card); color: var(--text); font-size: 14px; resize: none;
  min-height: 80px; font-family: inherit;
}
.correct-prompt .cp-actions { display: flex; gap: 8px; justify-content: flex-end; }
.correct-prompt .cp-actions button {
  padding: 10px 20px; border-radius: 12px; border: none; font-size: 14px; font-weight: 600; cursor: pointer;
}
.correct-prompt .btn-cancel { background: var(--bg-card); color: var(--text-muted); }
.correct-prompt .btn-submit { background: linear-gradient(135deg, var(--accent), var(--accent-purple)); color: #fff; }
</style>
</head>
<body>

<!-- ====== TOP BAR ====== -->
<div class="topbar">
  <div class="brand">🌌 <span>HEIMDALL</span></div>
  <div class="actions">
    <button id="btn-daily" title="日报">📋<span class="badge" id="badge-daily"></span></button>
    <button id="btn-corrections" title="修正摘要">📥<span class="badge" id="badge-correct"></span></button>
  </div>
</div>

<!-- ====== CONTENT ====== -->
<div class="content" id="content">

  <!-- CHAT PAGE -->
  <div class="page chat-page active" id="page-chat">
    <div class="chat-empty" id="chat-empty">
      <div class="icon">🌱</div>
      <h2>开始对话</h2>
      <p>聊聊你今天在想什么，知识环会自动记录和梳理</p>
      <div class="suggestions" id="chat-suggestions">
        <div class="suggestion" data-text="今天我学了 Transformer">今天我学了 Transformer</div>
        <div class="suggestion" data-text="认识了新同事王磊">认识了新同事王磊</div>
        <div class="suggestion" data-text="棕榈油供给收缩的原因">棕榈油供给收缩的原因</div>
      </div>
    </div>
    <div class="chat-msgs" id="chat-msgs"></div>
    <div class="typing-indicator" id="typing">
      <span></span><span></span><span></span>
    </div>
    <div class="chat-input-wrap">
      <textarea id="chat-input" rows="1" placeholder="输入消息..."></textarea>
      <button class="btn-mic" id="btn-mic" title="语音输入">🎤</button>
      <button class="btn-send" id="btn-send" title="发送">↑</button>
    </div>
  </div>

  <!-- RING PAGE -->
  <div class="page" id="page-ring">
    <!-- Ring Graph -->
    <div class="ring-graph-wrap" id="ring-graph-wrap">
      <svg id="ring-svg"></svg>
    </div>
    <div class="ring-graph-legend" id="ring-legend">
      <span><span class="lg-dot" style="background:#7c6aff"></span> 概念</span>
      <span><span class="lg-dot" style="background:#34d399"></span> 内容</span>
      <span><span class="lg-dot" style="background:#fbbf24"></span> 人物</span>
      <span><span class="lg-dot" style="background:#f87171"></span> 事件</span>
      <span><span class="lg-dot" style="background:#a78bfa"></span> 作品</span>
    </div>

    <!-- Stats bar -->
    <div class="stats-bar" id="ring-stats">
      <div class="stat-card"><div class="stat-num" id="stat-entities">—</div><div class="stat-label">实体</div></div>
      <div class="stat-card"><div class="stat-num" id="stat-relations">—</div><div class="stat-label">关系</div></div>
      <div class="stat-card"><div class="stat-num" id="stat-domains">—</div><div class="stat-label">领域</div></div>
    </div>

    <!-- Search -->
    <div class="search-wrap"><input type="text" id="ring-search" placeholder="搜索知识、人物、领域..."></div>

    <!-- Search results -->
    <div class="search-results" id="search-results"></div>

    <!-- Domain cards -->
    <div class="domain-list" id="domain-cards"></div>

    <!-- Empty state -->
    <div class="ring-empty" id="ring-empty" style="display:none">
      <svg class="ring-svg" viewBox="0 0 120 120">
        <circle cx="60" cy="60" r="45" fill="none" stroke="var(--border)" stroke-width="1.5" stroke-dasharray="6 4"/>
        <circle cx="60" cy="60" r="30" fill="none" stroke="var(--border)" stroke-width="1" stroke-dasharray="4 3"/>
        <circle cx="60" cy="60" r="6" fill="var(--accent)" class="dot"/>
      </svg>
      <h3>知识环还是空的</h3>
      <p>去聊聊天吧，它会在对话中自动生长</p>
    </div>
  </div>

  <!-- PROFILE PAGE -->
  <div class="page" id="page-profile">
    <div class="profile-header">
      <div class="profile-avatar">🌌</div>
      <h2>我的知识环</h2>
      <p>越用越懂你的长期记忆</p>
    </div>

    <div class="stats-bar">
      <div class="stat-card"><div class="stat-num" id="prof-entities">—</div><div class="stat-label">实体</div></div>
      <div class="stat-card"><div class="stat-num" id="prof-relations">—</div><div class="stat-label">关系</div></div>
      <div class="stat-card"><div class="stat-num" id="prof-domains">—</div><div class="stat-label">领域</div></div>
    </div>

    <div class="settings-group">
      <div class="sg-title">工具</div>
      <div class="settings-item" id="si-daily">
        <div class="si-left"><span class="si-icon">📋</span><div class="si-info"><span class="si-label">生成日报</span><span class="si-desc">查看今日知识增长详情</span></div></div>
        <span class="si-arrow">→</span>
      </div>
      <div class="settings-item" id="si-corrections">
        <div class="si-left"><span class="si-icon">📥</span><div class="si-info"><span class="si-label">修正摘要</span><span class="si-desc">查看本周自动确认和纠正记录</span></div></div>
        <span class="si-arrow">→</span>
      </div>
      <div class="settings-item" id="si-export">
        <div class="si-left"><span class="si-icon">📤</span><div class="si-info"><span class="si-label">导出数据</span><span class="si-desc">JSON / Markdown 格式</span></div></div>
        <span class="si-arrow">→</span>
      </div>
    </div>

    <div class="settings-group">
      <div class="sg-title">隐私与存储</div>
      <div class="settings-item">
        <div class="si-left"><span class="si-icon">🔐</span><span class="si-info"><span class="si-label">设备端加密</span><span class="si-desc">用户画像 AES-256 加密</span></span></div>
        <div class="toggle on" id="toggle-encryption"></div>
      </div>
      <div class="settings-item">
        <div class="si-left"><span class="si-icon">⏱</span><span class="si-info"><span class="si-label">情绪数据 TTL</span><span class="si-desc">7天自动清除</span></span></div>
        <span style="font-size:12px;color:var(--text-muted)">7天</span>
      </div>
      <div class="settings-item">
        <div class="si-left"><span class="si-icon">🗄</span><span class="si-info"><span class="si-label">原文归档</span><span class="si-desc">7天全文→30天摘要→90天归档</span></span></div>
        <span style="font-size:12px;color:var(--text-muted)">自动</span>
      </div>
    </div>
  </div>

</div>

<!-- ====== BOTTOM NAV ====== -->
<div class="bottom-nav">
  <button class="active" data-page="chat">
    <span class="nav-icon">💬</span>对话
  </button>
  <button data-page="ring">
    <span class="nav-icon">🌌</span>知识环
  </button>
  <button data-page="profile">
    <span class="nav-icon">⚙️</span>我的
  </button>
</div>

<!-- ====== OVERLAYS ====== -->

<!-- Backdrop -->
<div class="overlay" id="overlay"></div>

<!-- Bottom sheet: entity detail -->
<div class="bottom-sheet" id="bottom-sheet">
  <div class="bs-handle"></div>
  <div class="bs-content" id="bs-content"></div>
</div>

<!-- Daily report modal -->
<div class="modal" id="modal-daily">
  <div class="modal-box">
    <button class="modal-close" id="modal-close-daily">✕</button>
    <h3>📋 日报</h3>
    <p style="font-size:12px;color:var(--text-muted)" id="daily-date"></p>
    <div class="modal-section"><h4>🌿 今日知识增长</h4><div id="daily-growth"></div></div>
    <div class="modal-section"><h4>👥 社交更新</h4><div id="daily-social"></div></div>
    <div class="modal-section" style="font-size:12px;color:var(--text-muted)" id="daily-summary"></div>
  </div>
</div>

<!-- Correction summary modal -->
<div class="modal" id="modal-corrections">
  <div class="modal-box">
    <button class="modal-close" id="modal-close-correct">✕</button>
    <h3>📥 本周修正摘要</h3>
    <p style="font-size:12px;color:var(--text-muted)" id="correct-count"></p>
    <div class="modal-section" id="correct-list"></div>
  </div>
</div>

<!-- Correction prompt -->
<div class="correct-overlay" id="correct-overlay">
  <div class="correct-prompt">
    <h4>✏️ 纠错</h4>
    <textarea id="correct-input" placeholder="请输入纠正内容，例如：类型改为 person，role 改为技术总监"></textarea>
    <div class="cp-actions">
      <button class="btn-cancel" id="correct-cancel">取消</button>
      <button class="btn-submit" id="correct-submit">提交纠错</button>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
// =======================================================================
// HEIMDALL Mobile App — V2.2
// =======================================================================

const API = '/api/v1';
let _messages = [];
let _entities = [];
let _currentEntityId = null;
let _isRecording = false;
let _isStreaming = false;

// ====== DOM refs ======
const $ = (s) => document.querySelector(s);
const $$ = (s) => document.querySelectorAll(s);

// ====== Navigation ======
$$('.bottom-nav button').forEach(btn => {
  btn.addEventListener('click', () => {
    $$('.bottom-nav button').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const page = btn.dataset.page;
    $$('.page').forEach(p => p.classList.remove('active'));
    $(`#page-${page}`).classList.add('active');
    if (page === 'ring') loadRingData();
    if (page === 'profile') loadProfileData();
  });
});

// ====== Toast ======
function showToast(msg, type = '') {
  const t = $('#toast');
  t.textContent = msg; t.className = 'toast ' + type + ' show';
  clearTimeout(t._tid);
  t._tid = setTimeout(() => t.classList.remove('show'), 2500);
}

// ====== Overlay / Backdrop ======
$('#overlay').addEventListener('click', closeAll);

function closeAll() {
  $('#overlay').classList.remove('open');
  $('#bottom-sheet').classList.remove('open');
  $('#modal-daily').classList.remove('open');
  $('#modal-corrections').classList.remove('open');
  $('#correct-overlay').classList.remove('open');
}

// ====== Bottom Sheet ======
function openEntitySheet(entityId) {
  fetch(`${API}/entity/${entityId}`)
    .then(r => r.json())
    .then(data => {
      const ent = data.entity || data;
      if (!ent) return;
      _currentEntityId = entityId;
      const type = ent.type || (ent.types && ent.types[0]) || 'concept';
      const typeLabel = {concept:'概念',content:'内容',person:'人物',event:'事件',artifact:'作品'}[type] || type;
      const domains = ent.domains || [];
      const rels = ent.relations || data.relations || [];

      let relHTML = rels.slice(0, 5).map(r =>
        `<div class="bs-rel-item">
          <span style="font-size:18px">🔗</span>
          <span>${esc(r.source_name||'?')} <span class="bs-rel-type">${esc(r.type||'')}</span> ${esc(r.target_name||'?')}</span>
        </div>`
      ).join('') || '<div style="font-size:12px;color:var(--text-muted)">暂无关系</div>';

      let domainHTML = domains.length ? domains.map(d =>
        `<span class="bs-domain-tag">${esc(d)}</span>`
      ).join('') : '<span style="font-size:12px;color:var(--text-muted)">暂无领域</span>';

      $('#bs-content').innerHTML = `
        <div style="display:flex;align-items:center;gap:8px">
          <span style="font-size:28px">📘</span>
          <div>
            <div class="bs-entity-name">${esc(ent.name||'未知')}</div>
            <span class="bs-entity-type type-${type}">${typeLabel}</span>
          </div>
        </div>
        <div class="bs-section"><h4>领域</h4><div class="bs-domain-tags">${domainHTML}</div></div>
        <div class="bs-section"><h4>关系 (${rels.length})</h4><div class="bs-relations">${relHTML}</div></div>
        <button class="btn-correct" onclick="openCorrection('${entityId}')">✏️ 纠错</button>
      `;

      $('#bottom-sheet').classList.add('open');
      $('#overlay').classList.add('open');
    })
    .catch(e => showToast('加载实体详情失败', 'error'));
}

// ====== Correction ======
function openCorrection(entityId) {
  _currentEntityId = entityId;
  $('#correct-overlay').classList.add('open');
}

$('#correct-cancel').addEventListener('click', () => $('#correct-overlay').classList.remove('open'));

$('#correct-submit').addEventListener('click', () => {
  const text = $('#correct-input').value.trim();
  if (!text) return;
  fetch(`${API}/entity/${_currentEntityId}/correct`, {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({correction: text}),
  })
  .then(r => r.json())
  .then(() => {
    showToast('已记录纠错', 'success');
    $('#correct-overlay').classList.remove('open');
    $('#correct-input').value = '';
    closeAll();
  })
  .catch(() => showToast('纠错失败', 'error'));
});

// ====== Daily Report Modal ======
$('#btn-daily').addEventListener('click', openDailyReport);
$('#si-daily').addEventListener('click', () => { switchTab('ring'); openDailyReport(); });

function openDailyReport() {
  const today = new Date().toISOString().slice(0,10);
  fetch(`${API}/daily-report?date=${today}`)
    .then(r => r.json())
    .then(data => {
      $('#daily-date').textContent = `📅 ${today} · 知识增长`;
      const growth = data.growth || data.domain_growth || [];
      $('#daily-growth').innerHTML = growth.length
        ? growth.map(g => `<div class="modal-item">▸ ${esc(g.domain||g.name||'')} +${g.cnt||g.count||0} 实体</div>`).join('')
        : '<div style="font-size:12px;color:var(--text-muted)">暂无增长</div>';
      const social = data.social || [];
      $('#daily-social').innerHTML = social.length
        ? social.map(s => `<div class="modal-item">▸ ${esc(s.description||s.name||'')}</div>`).join('')
        : '<div style="font-size:12px;color:var(--text-muted)">暂无社交更新</div>';
      const entities = data.total_entities || data.entity_count || '—';
      const relations = data.total_relations || data.relation_count || '—';
      const domains = data.total_domains || data.domain_count || '—';
      const streak = data.streak || 0;
      $('#daily-summary').textContent = `📊 累计 ${entities} 实体 · ${relations} 关系 · ${domains} 领域 · 🔥 连续 ${streak} 天`;
      $('#modal-daily').classList.add('open');
    })
    .catch(() => showToast('加载日报失败', 'error'));
}

$('#modal-close-daily').addEventListener('click', closeAll);

// ====== Correction Summary Modal ======
$('#btn-corrections').addEventListener('click', openCorrectionSummary);
$('#si-corrections').addEventListener('click', () => { switchTab('profile'); openCorrectionSummary(); });

function openCorrectionSummary() {
  const today = new Date();
  const dayOfWeek = today.getDay();
  const monday = new Date(today);
  monday.setDate(today.getDate() - ((dayOfWeek + 6) % 7));
  const weekStart = monday.toISOString().slice(0,10);

  fetch(`${API}/daily-report?date=${weekStart}`)
    .then(r => r.json())
    .then(data => {
      const events = data.events || [];
      const corrections = events.filter(e => e.event_type === 'user_correction' || e.event_type === 'field_edited');
      $('#correct-count').textContent = `AI 本周自动确认了 ${events.length} 条记录`;
      $('#correct-list').innerHTML = corrections.length
        ? corrections.map((c,i) => `
          <div class="modal-item">
            ${i+1}. "${esc(c.entity_id||'')}" ${esc(c.description||'')}
            <br><span class="modal-arrow">← ${esc(c.old_value||'')}</span>
            <br><span class="modal-arrow">→ ${esc(c.new_value||'')}</span>
          </div>`).join('')
        : '<div style="font-size:12px;color:var(--text-muted)">本周暂无纠正记录</div>';
      $('#modal-corrections').classList.add('open');
    })
    .catch(() => showToast('加载修正摘要失败', 'error'));
}

$('#modal-close-correct').addEventListener('click', closeAll);

// ====== Tab switching helper ======
function switchTab(name) {
  $$('.bottom-nav button').forEach(b => b.classList.remove('active'));
  const btn = $(`.bottom-nav button[data-page="${name}"]`);
  if (btn) btn.classList.add('active');
  $$('.page').forEach(p => p.classList.remove('active'));
  $(`#page-${name}`).classList.add('active');
}

// ====== Toggle ======
$('#toggle-encryption').addEventListener('click', function() {
  this.classList.toggle('on');
  const on = this.classList.contains('on');
  showToast(on ? '设备端加密已开启' : '设备端加密已关闭', on ? 'success' : '');
});

// ====== Ring Data Loading ======
let _ringNodes = [];
let _ringEdges = [];

function loadRingData() {
  fetch(`${API}/ring`)
    .then(r => r.json())
    .then(data => {
      const nodes = data.nodes || [];
      const edges = data.edges || [];
      _entities = nodes;
      _ringNodes = nodes;
      _ringEdges = edges;

      // Stats
      const domains = new Set();
      nodes.forEach(n => {
        let d = n.domains || [];
        if (!Array.isArray(d) || d.length === 0) d = ['未分类'];
        d.forEach(dd => domains.add(dd));
      });

      $('#stat-entities').textContent = nodes.length;
      $('#stat-relations').textContent = edges.length;
      $('#stat-domains').textContent = domains.size;

      // Render ring graph
      renderMobileRingGraph(nodes, edges);

      // Domain cards
      const domainMap = {};
      nodes.forEach(n => {
        let ds = n.domains || [];
        if (Array.isArray(ds) && ds.length === 0) ds = ['未分类'];
        else if (!Array.isArray(ds)) ds = ['未分类'];
        ds.forEach(d => {
          if (!domainMap[d]) domainMap[d] = { entities: [], isNew: false };
          domainMap[d].entities.push(n);
        });
      });

      const cardColors = ['#7c6aff','#5b9aff','#34d399','#fbbf24','#f472b6','#22d3ee','#f87171'];
      let idx = 0;
      const cards = Object.entries(domainMap).sort((a,b) => b[1].entities.length - a[1].entities.length);
      const cardsHTML = cards.map(([name, info]) => {
        const color = cardColors[idx % cardColors.length]; idx++;
        const tags = info.entities.slice(0, 4).map(e =>
          `<span class="dc-tag" onclick="event.stopPropagation();openEntitySheet('${esc(e.entity_id)}')">${esc(e.name)}</span>`
        ).join('');
        return `
          <div class="domain-card" onclick="searchDomain('${esc(name)}')">
            <div class="dc-left" style="background:${color}"></div>
            <div class="dc-header">
              <span class="dc-name">🌿 ${esc(name)}</span>
              <span class="dc-count">+${info.entities.length} 实体</span>
              ${info.isNew ? '<span class="dc-new">NEW</span>' : ''}
            </div>
            <div class="dc-tags">${tags}</div>
          </div>`;
      }).join('');

      $('#domain-cards').innerHTML = cardsHTML || '';
      $('#ring-empty').style.display = nodes.length === 0 ? 'flex' : 'none';
    })
    .catch(() => {
      $('#stat-entities').textContent = '—';
      $('#stat-relations').textContent = '—';
      $('#stat-domains').textContent = '—';
    });
}

// ====== Ring Graph Rendering (Circles-only, Color-coded, Ring Layout, Collision Avoidance) ======
const RING_COLORS = {
  concept: '#7c6aff', content: '#34d399', person: '#fbbf24',
  event: '#f87171', artifact: '#a78bfa'
};

function renderMobileRingGraph(nodes, edges) {
  const wrap = document.getElementById('ring-graph-wrap');
  const svg = document.getElementById('ring-svg');
  if (!wrap || !svg) return;

  const W = wrap.clientWidth || 360;
  const H = wrap.clientHeight || 280;
  svg.setAttribute('viewBox', `0 0 ${W} ${H}`);
  svg.innerHTML = '';

  if (!nodes.length) {
    svg.innerHTML = `<text x="${W/2}" y="${H/2}" text-anchor="middle" fill="#9898b0" font-size="13" font-family="sans-serif">聊聊天，知识环会自然生长</text>`;
    return;
  }

  const cx = W / 2, cy = H / 2;
  const maxR = Math.min(W, H) * 0.40;

  // Prepare visible nodes (max 200 for mobile performance)
  const visible = nodes.slice(0, 200).map(n => {
    const type = (n.types && n.types[0]) || n.type || 'concept';
    return {
      ...n,
      _type: type,
      _color: RING_COLORS[type] || '#6b6b85',
      _r: 6 + (n.confidence || 0.5) * 10,
      _label: (n.name || '').length > 8 ? (n.name || '').slice(0, 7) + '…' : (n.name || '')
    };
  });

  // Sort: higher confidence → inner rings
  visible.sort((a, b) => (b.confidence || 0) - (a.confidence || 0));

  // Place nodes in concentric rings
  const rings = [[], [], [], []];
  visible.forEach((n, i) => {
    if (i < visible.length * 0.15) rings[0].push(n);
    else if (i < visible.length * 0.40) rings[1].push(n);
    else if (i < visible.length * 0.70) rings[2].push(n);
    else rings[3].push(n);
  });

  const ringRadii = [maxR * 0.18, maxR * 0.38, maxR * 0.58, maxR * 0.78];
  rings.forEach((ring, ri) => {
    ring.forEach((n, i) => {
      const angle = (2 * Math.PI * i) / ring.length - Math.PI / 2;
      const r = ringRadii[ri] + (Math.random() - 0.5) * 20;
      n._x = cx + r * Math.cos(angle);
      n._y = cy + r * Math.sin(angle);
      n._vx = 0; n._vy = 0;
    });
  });

  const allNodes = visible;
  const nodeIdx = new Map();
  allNodes.forEach(n => nodeIdx.set(n.entity_id, n));

  // Build edge neighbor map
  const neighbors = new Map();
  allNodes.forEach(n => neighbors.set(n.entity_id, new Set()));
  edges.forEach(e => {
    const sa = neighbors.get(e.source_id);
    const ta = neighbors.get(e.target_id);
    if (sa) sa.add(e.target_id);
    if (ta) ta.add(e.source_id);
  });

  // Force simulation with collision avoidance
  const iterations = 80;
  for (let iter = 0; iter < iterations; iter++) {
    const alpha = 1 - iter / iterations;
    const alpha2 = alpha * alpha;

    // Repulsion
    for (let i = 0; i < allNodes.length; i++) {
      for (let j = i + 1; j < allNodes.length; j++) {
        const a = allNodes[i], b = allNodes[j];
        let dx = b._x - a._x, dy = b._y - a._y;
        let dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 1) { dist = 1; dx = 1; dy = 0; }
        const minDist = a._r + b._r + 6;
        if (dist < minDist) {
          const force = (minDist - dist) * 0.15 * alpha;
          const fx = (dx / dist) * force;
          const fy = (dy / dist) * force;
          a._vx -= fx; a._vy -= fy;
          b._vx += fx; b._vy += fy;
        }
      }
    }

    // Edge attraction
    edges.forEach(e => {
      const s = nodeIdx.get(e.source_id);
      const t = nodeIdx.get(e.target_id);
      if (!s || !t) return;
      let dx = t._x - s._x, dy = t._y - s._y;
      let dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < 1) { dist = 1; dx = 1; dy = 0; }
      const rest = (s._r + t._r) * 2.5 + 20;
      const force = (dist - rest) * 0.02 * alpha;
      const fx = (dx / dist) * force;
      const fy = (dy / dist) * force;
      s._vx += fx; s._vy += fy;
      t._vx -= fx; t._vy -= fy;
    });

    // Center gravity
    allNodes.forEach(n => {
      n._vx += (cx - n._x) * 0.003;
      n._vy += (cy - n._y) * 0.003;
    });

    // Apply velocity
    allNodes.forEach(n => {
      n._vx *= 0.5;
      n._vy *= 0.5;
      n._x += n._vx;
      n._y += n._vy;
    });

    // Clamp to viewport
    allNodes.forEach(n => {
      n._x = Math.max(n._r, Math.min(W - n._r, n._x));
      n._y = Math.max(n._r, Math.min(H - n._r, n._y));
    });
  }

  // Render edges
  const edgeGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
  edges.forEach(e => {
    const s = nodeIdx.get(e.source_id);
    const t = nodeIdx.get(e.target_id);
    if (!s || !t) return;
    const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
    line.setAttribute('x1', s._x); line.setAttribute('y1', s._y);
    line.setAttribute('x2', t._x); line.setAttribute('y2', t._y);
    line.setAttribute('stroke', '#3a3a55');
    line.setAttribute('stroke-width', Math.max(0.4, (e.confidence || 0.5) * 1.5));
    line.setAttribute('opacity', '0.3');
    edgeGroup.appendChild(line);
  });
  svg.appendChild(edgeGroup);

  // Render nodes (circles only, color-coded)
  const nodeGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
  allNodes.forEach(n => {
    const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
    g.setAttribute('transform', `translate(${n._x},${n._y})`);
    g.style.cursor = 'pointer';
    g.setAttribute('data-eid', n.entity_id);

    const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    circle.setAttribute('r', n._r);
    circle.setAttribute('fill', n._color);
    circle.setAttribute('opacity', '0.88');
    circle.setAttribute('stroke', '#0a0a0f');
    circle.setAttribute('stroke-width', '1.2');
    g.appendChild(circle);

    // Label for medium+ nodes
    if (n._r > 7) {
      const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      text.setAttribute('y', n._r + 10);
      text.setAttribute('text-anchor', 'middle');
      text.setAttribute('fill', '#9898b0');
      text.setAttribute('font-size', '8');
      text.setAttribute('font-family', 'sans-serif');
      text.textContent = n._label;
      g.appendChild(text);
    }

    g.addEventListener('click', (ev) => {
      ev.stopPropagation();
      openEntitySheet(n.entity_id);
    });

    nodeGroup.appendChild(g);
  });
  svg.appendChild(nodeGroup);

  // Touch zoom + pan
  let scale = 1, panX = 0, panY = 0;
  let pinchStartDist = 0, pinchStartScale = 1;
  let dragStartX = 0, dragStartY = 0, dragPanX = 0, dragPanY = 0, dragging = false;

  const updateTransform = () => {
    nodeGroup.setAttribute('transform', `translate(${panX},${panY}) scale(${scale})`);
    edgeGroup.setAttribute('transform', `translate(${panX},${panY}) scale(${scale})`);
  };

  // Mouse wheel zoom
  svg.onwheel = (e) => {
    e.preventDefault();
    const old = scale;
    scale *= e.deltaY < 0 ? 1.1 : 0.9;
    scale = Math.max(0.3, Math.min(3, scale));
    const rect = svg.getBoundingClientRect();
    const mx = e.clientX - rect.left, my = e.clientY - rect.top;
    panX = mx - (mx - panX) * (scale / old);
    panY = my - (my - panY) * (scale / old);
    updateTransform();
  };

  // Touch events
  svg.addEventListener('touchstart', (e) => {
    if (e.touches.length === 2) {
      const dx = e.touches[0].clientX - e.touches[1].clientX;
      const dy = e.touches[0].clientY - e.touches[1].clientY;
      pinchStartDist = Math.sqrt(dx * dx + dy * dy);
      pinchStartScale = scale;
      dragging = false;
    } else if (e.touches.length === 1) {
      dragging = true;
      dragStartX = e.touches[0].clientX;
      dragStartY = e.touches[0].clientY;
      dragPanX = panX;
      dragPanY = panY;
    }
  }, { passive: false });

  svg.addEventListener('touchmove', (e) => {
    e.preventDefault();
    if (e.touches.length === 2) {
      const dx = e.touches[0].clientX - e.touches[1].clientX;
      const dy = e.touches[0].clientY - e.touches[1].clientY;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (pinchStartDist > 0) {
        scale = Math.max(0.3, Math.min(3, pinchStartScale * (dist / pinchStartDist)));
        updateTransform();
      }
    } else if (e.touches.length === 1 && dragging) {
      panX = dragPanX + (e.touches[0].clientX - dragStartX);
      panY = dragPanY + (e.touches[0].clientY - dragStartY);
      updateTransform();
    }
  }, { passive: false });

  svg.addEventListener('touchend', () => { dragging = false; });
}

// Search
let _searchTimeout;
$('#ring-search').addEventListener('input', function() {
  clearTimeout(_searchTimeout);
  const q = this.value.trim();
  if (!q) {
    $('#search-results').classList.remove('open');
    $('#domain-cards').style.display = '';
    return;
  }
  _searchTimeout = setTimeout(() => {
    const matched = _entities.filter(e =>
      (e.name||'').toLowerCase().includes(q.toLowerCase()) ||
      ((e.type_detail||'')+'').includes(q)
    );
    renderSearchResults(matched);
  }, 200);
});

function searchDomain(name) {
  $('#ring-search').value = name;
  const matched = _entities.filter(e => {
    let ds = e.domains || [];
    if (!Array.isArray(ds) || ds.length === 0) ds = ['未分类'];
    return ds.some(d => d === name);
  });
  renderSearchResults(matched);
}

function renderSearchResults(items) {
  if (!items.length) {
    $('#search-results').innerHTML = '<div style="text-align:center;padding:24px;color:var(--text-muted)">换个关键词试试</div>';
  } else {
    $('#search-results').innerHTML = items.map(e => {
      const type = (e.types && e.types[0]) || e.type || 'concept';
      const typeLabel = {concept:'概念',content:'内容',person:'人物',event:'事件',artifact:'作品'}[type] || type;
      const icon = {concept:'📘',content:'📄',person:'👤',event:'📅',artifact:'🏗️'}[type] || '📘';
      return `
        <div class="search-result-item" onclick="openEntitySheet('${esc(e.entity_id)}')">
          <span class="sri-icon">${icon}</span>
          <div class="sri-info">
            <div class="sri-name">${esc(e.name)}</div>
            <div class="sri-sub">${esc(e.type_detail||'')}</div>
          </div>
          <span class="sri-type type-${type}">${typeLabel}</span>
        </div>`;
    }).join('');
  }
  $('#search-results').classList.add('open');
  $('#domain-cards').style.display = 'none';
}

// ====== Profile Data ======
function loadProfileData() {
  fetch(`${API}/ring`)
    .then(r => r.json())
    .then(data => {
      const nodes = data.nodes || [];
      const edges = data.edges || [];
      const domains = new Set();
      nodes.forEach(n => { (Array.isArray(n.domains||[]) ? n.domains : []).forEach(d => domains.add(d)); });
      $('#prof-entities').textContent = nodes.length;
      $('#prof-relations').textContent = edges.length;
      $('#prof-domains').textContent = domains.size;
    })
    .catch(() => {});
}

// Export
$('#si-export').addEventListener('click', () => {
  showToast('导出功能即将推出', '');
});

// ====== Chat ======
// Suggestion clicks
$$('.suggestion').forEach(el => {
  el.addEventListener('click', () => {
    const text = el.dataset.text;
    $('#chat-input').value = text;
    sendMessage();
  });
});

// Send message
$('#btn-send').addEventListener('click', sendMessage);

$('#chat-input').addEventListener('keydown', function(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
});

// Auto-resize textarea
$('#chat-input').addEventListener('input', function() {
  this.style.height = 'auto';
  this.style.height = Math.min(this.scrollHeight, 120) + 'px';
});

// Mic button
$('#btn-mic').addEventListener('click', function() {
  _isRecording = !_isRecording;
  if (_isRecording) {
    this.classList.add('recording');
    showToast('正在录音...', '');
  } else {
    this.classList.remove('recording');
    showToast('录音结束', 'success');
  }
});

function sendMessage() {
  const input = $('#chat-input');
  const text = input.value.trim();
  if (!text || _isStreaming) return;

  _isStreaming = true;
  $('#chat-empty').style.display = 'none';
  $('#btn-send').textContent = '⏹';
  $('#btn-send').classList.add('btn-stop');

  // Add user message
  addMessage('user', text);
  input.value = '';
  input.style.height = '40px';

  // Show typing indicator
  const typing = $('#typing');
  typing.classList.add('show');

  // Call chat API
  fetch('/api/chat/stream', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({message: text, session_id: localStorage.getItem('hsid') || ''}),
  })
  .then(async r => {
    const hsid = r.headers.get('X-Session-Id') || r.headers.get('x-session-id');
    if (hsid) localStorage.setItem('hsid', hsid);

    typing.classList.remove('show');
    const aiMsg = addMessage('assistant', '');

    const reader = r.body.getReader();
    const decoder = new TextDecoder();
    let content = '';

    while (true) {
      const {done, value} = await reader.read();
      if (done) break;
      const chunk = decoder.decode(value, {stream: true});
      // Parse SSE
      const lines = chunk.split('\n');
      for (const line of lines) {
        if (line.startsWith('data: ')) {
          try {
            const d = JSON.parse(line.slice(6));
            if (d.text) content += d.text;
          } catch(e) {
            content += line.slice(6);
          }
        }
      }
      aiMsg.querySelector('.msg-bubble').textContent = content || '(空响应)';
      document.querySelector('.chat-msgs').scrollTop = document.querySelector('.chat-msgs').scrollHeight;
    }
  })
  .catch(() => {
    typing.classList.remove('show');
    addMessage('assistant', '抱歉，请求失败了。请稍后重试。');
  })
  .finally(() => {
    _isStreaming = false;
    $('#btn-send').textContent = '↑';
    $('#btn-send').classList.remove('btn-stop');
    // Auto-refresh ring data after 1.5s
    setTimeout(() => { if ($('#page-ring').classList.contains('active')) loadRingData(); }, 1500);
  });
}

function addMessage(role, text) {
  const msgs = $('#chat-msgs');
  const isUser = role === 'user';
  const avatar = isUser ? '👤' : '🤖';
  const div = document.createElement('div');
  div.className = `msg-row ${role}`;
  div.innerHTML = `
    <div class="msg-avatar">${avatar}</div>
    <div class="msg-bubble">${esc(text)}</div>
  `;
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
  return div;
}

// ====== Utility ======
function esc(s) {
  if (!s) return '';
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

// ====== Init ======
loadRingData();
</script>

</body>
</html>
