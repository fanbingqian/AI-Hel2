{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "AI-Hel2",
  "version": "0.1.3",
  "identifier": "com.aihel2.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && powershell -Command \"Compress-Archive -Path src-tauri\\hermes-agent\\* -DestinationPath src-tauri\\hermes-agent.zip -Force\" && powershell -File src-tauri\\copy-agent.ps1"
  },
  "app": {
    "windows": [
      {
        "title": "AI-Hel2",
        "width": 390,
        "height": 693,
        "minWidth": 340,
        "minHeight": 500,
        "center": true,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' data: https:; media-src 'self' data: https://asset.localhost; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "hermes-agent.zip"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVCQjE2NDhGQkNGQ0RDNUIKUldSYjNQeThqMlN4NjByLy9UWndENkh2LzM4Vi9oNWhnMEU0d09IZTlzQnR5cFFGVkpibDYvcHoK",
      "endpoints": [
        "https://github.com/fanbingqian/AI-Hel2/releases/latest/download/latest.json"
      ]
    }
  }
}
