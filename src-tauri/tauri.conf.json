{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "AI-Hel2",
  "version": "0.1.0",
  "identifier": "com.aihel2.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AI-Hel2",
        "width": 390,
        "height": 693,
        "minWidth": 340,
        "minHeight": 500,
        "center": true,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' data: https:; media-src 'self' data: https://asset.localhost; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "hermes-agent/*.py",
      "hermes-agent/*.toml",
      "hermes-agent/hermes_cli/*.py",
      "hermes-agent/agent/*.py",
      "hermes-agent/agent/**/*.py",
      "hermes-agent/tools/*.py",
      "hermes-agent/tools/**/*.py",
      "hermes-agent/providers/*.py",
      "hermes-agent/heimdall/*.py",
      "hermes-agent/heimdall/**/*.py",
      "hermes-agent/gateway/*.py",
      "hermes-agent/cron/*.py",
      "hermes-agent/plugins/*.py",
      "hermes-agent/plugins/**/*.py",
      "hermes-agent/skills/**/*.md",
      "hermes-agent/skills/**/*.py",
      "hermes-agent/optional-skills/**/*.md",
      "hermes-agent/optional-skills/**/*.py",
      "hermes-agent/acp_adapter/*.py",
      "hermes-agent/venv/**/*",
      "hermes-agent/python/*.exe",
      "hermes-agent/python/*.dll",
      "hermes-agent/python/*.pyd",
      "hermes-agent/python/*.cat",
      "hermes-agent/python/*.zip",
      "hermes-agent/python/*._pth",
      "hermes-agent/python/Lib/**/*"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
